---
const examples = [
  { label: "API keys", hint: "aws_secret, gh_pat, openai_sk" },
  { label: "Source code", hint: "proprietary repos, IP" },
  { label: "Customer PII", hint: "names, IDs, emails, IBAN" },
  { label: "Infra secrets", hint: "connection strings, .env" },
];
---

<section id="problem" class="border-b border-[var(--color-cloud)] bg-white py-24 md:py-32">
  <div class="container-x">
    <div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:gap-20">
      <div>
        <h2 class="h-section text-[var(--color-phantom)]">
          Traditional DLP wasn't built for the chatbot era.
        </h2>
        <p class="body-lg mt-6 max-w-[480px]">
          21% of EU companies already use AI. 90% of developers use it daily. Only 16% receive formal training.
          Every day, employees paste data into chatbots that your DLP can't see.
        </p>

        <div class="mt-10 rounded-2xl border border-[var(--color-cloud)] bg-[var(--color-brand-light)]/60 p-6">
          <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-[var(--color-graphite)]">The gap</p>
          <p class="mt-3 text-[16px] leading-relaxed text-[var(--color-phantom)]">
            Forcepoint, Symantec, Nightfall watch network, email and USB.
            <span class="font-semibold text-[var(--color-brand-purple)]">None of them watch the DOM of a chatbot.</span>
          </p>
        </div>
      </div>

      <div class="space-y-3">
        <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-[var(--color-graphite)]">
          What ends up in the prompt
        </p>
        <div class="grid grid-cols-2 gap-3">
          {examples.map((ex) => (
            <div class="surface-card group">
              <div class="flex items-start justify-between">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-[var(--color-brand-purple)]/10 text-[var(--color-brand-purple)] transition group-hover:bg-[var(--color-brand-purple)] group-hover:text-white">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5"/>
                    <path d="M2 12l10 5 10-5"/>
                  </svg>
                </div>
                <span class="text-[10px] font-bold uppercase tracking-[0.12em] text-[var(--color-danger)]">High risk</span>
              </div>
              <p class="h-card mt-5 text-[var(--color-phantom)]">{ex.label}</p>
              <p class="mt-1 font-mono text-[11px] text-[var(--color-graphite)]">{ex.hint}</p>
            </div>
          ))}
        </div>

        <div class="surface-card flex items-center gap-4 !p-5">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-warn)]/10 text-[var(--color-warn)]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
          <p class="text-[14px] leading-snug text-[var(--color-arsenic)]">
            <span class="font-semibold text-[var(--color-phantom)]">Invisible by default.</span>
            Pasted secrets train models or sit in vendor logs forever.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

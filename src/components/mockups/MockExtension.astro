---
---

<div class="thld-mock-frame thld-extension" style="--mock-w: 980; --mock-h: 320;">
  <div class="thld-mock-content">
    <div style="width: 980px; border-radius: 14px; background: #dee1e6; box-shadow: 0 30px 80px -20px rgba(2,14,45,0.45), 0 10px 30px -12px rgba(2,14,45,0.3); overflow: visible; position: relative; font-family: 'Manrope Variable', system-ui, sans-serif;">

      <!-- Tab strip -->
      <div style="display: flex; align-items: flex-end; gap: 0; height: 46px; padding: 8px 10px 0 10px;">
        <div style="display: flex; align-items: center; gap: 9px; background: #ffffff; border-radius: 10px 10px 0 0; height: 38px; padding: 0 16px 0 14px; min-width: 230px; box-shadow: 0 -1px 0 rgba(0,0,0,0.02);">
          <div style="width: 16px; height: 16px; border-radius: 5px; background: #7b36ff; display: flex; align-items: center; justify-content: center; flex: none;">
            <img src="/emblem-white.svg" alt="" style="width: 11px; height: 11px; object-fit: contain;" />
          </div>
          <span style="font-size: 12.5px; color: #3c4043; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Tracehold: AI-native DLP</span>
          <div style="width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #5f6368; margin-left: 4px; flex: none;">
            <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><path d="M1 1L9 9M9 1L1 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          </div>
        </div>
        <div style="display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; margin: 0 0 5px 6px; color: #5f6368; flex: none;">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
      </div>

      <!-- Toolbar -->
      <div style="background: #ffffff; display: flex; align-items: center; gap: 10px; padding: 9px 14px;">
        <div style="display: flex; align-items: center; gap: 4px; color: #5f6368;">
          <div style="width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M15 5l-7 7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          <div style="width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #bdc1c6;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          <div style="width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M4 12a8 8 0 1 1 2.3 5.6M4 12V7m0 5h5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        </div>

        <div style="flex: 1; height: 34px; background: #f1f3f4; border-radius: 17px; display: flex; align-items: center; gap: 10px; padding: 0 16px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" style="color: #5f6368; flex: none;"><rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="2"/></svg>
          <span style="font-size: 13px; color: #3c4043;">tracehold.com</span>
        </div>

        <div style="display: flex; align-items: center; gap: 2px; color: #5f6368;">
          <div style="position: relative;">
            <div style="width: 34px; height: 34px; border-radius: 50%; background: #e8e0fb; display: flex; align-items: center; justify-content: center; color: #7b36ff;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M14.5 3.5a2 2 0 1 0-4 0V6H8a2 2 0 0 0-2 2v2.5H3.5a2 2 0 1 0 0 4H6V17a2 2 0 0 0 2 2h2.5v-2.5a2 2 0 1 1 4 0V19H17a2 2 0 0 0 2-2v-2.5a2 2 0 1 0 0-4V8a2 2 0 0 0-2-2h-2.5V3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            </div>
          </div>
          <div style="width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M12 3l2.5 5.5 6 .5-4.5 4 1.4 6L12 16l-5.4 3 1.4-6L3.5 9l6-.5L12 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg></div>
          <div style="width: 30px; height: 30px; border-radius: 50%; background: #7b36ff; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; margin-left: 4px;">A</div>
          <div style="width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="5" r="1.7" fill="currentColor"/><circle cx="12" cy="12" r="1.7" fill="currentColor"/><circle cx="12" cy="19" r="1.7" fill="currentColor"/></svg></div>
        </div>
      </div>

      <!-- page area under toolbar -->
      <div style="height: 120px; background: linear-gradient(180deg, #ffffff, #f7f8fb); border-radius: 0 0 14px 14px;"></div>

      <!-- Extensions dropdown panel -->
      <div style="position: absolute; top: 88px; right: 82px; width: 332px; background: #ffffff; border-radius: 14px; box-shadow: 0 16px 48px -8px rgba(2,14,45,0.32), 0 4px 14px -4px rgba(2,14,45,0.18); overflow: hidden; border: 1px solid rgba(2,14,45,0.06);">
        <div style="position: absolute; top: -7px; right: 24px; width: 14px; height: 14px; background: #ffffff; transform: rotate(45deg); border-left: 1px solid rgba(2,14,45,0.06); border-top: 1px solid rgba(2,14,45,0.06);"></div>

        <div style="padding: 16px 18px 10px 18px;">
          <div style="font-size: 15px; font-weight: 600; color: #202124;">Extensions</div>
        </div>

        <div style="padding: 4px 18px 6px 18px; font-size: 11px; font-weight: 600; letter-spacing: 0.04em; color: #80868b; text-transform: uppercase;">Full access</div>

        <div style="display: flex; align-items: center; gap: 12px; padding: 9px 12px 9px 18px;">
          <div style="width: 28px; height: 28px; border-radius: 8px; background: #7b36ff; display: flex; align-items: center; justify-content: center; flex: none; box-shadow: 0 2px 6px -1px rgba(123,54,255,0.5);">
            <img src="/emblem-white.svg" alt="Tracehold" style="width: 18px; height: 18px; object-fit: contain;" />
          </div>
          <div style="flex: 1; min-width: 0;">
            <div style="font-size: 13.5px; color: #202124; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Tracehold</div>
            <div style="font-size: 11.5px; color: #5f6368; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">AI-native DLP</div>
          </div>
          <div style="width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #7b36ff; flex: none;">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M14 4l6 6-1.4 1.4-.6-.6-3.5 3.5.2 4.3-1.4 1.4-3.6-3.6L5 21l-.7-.7 4.7-4.9L5.4 11.8 6.8 10.4l4.3.2 3.5-3.5-.6-.6L14 4z"/></svg>
          </div>
          <div style="width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #5f6368; flex: none;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="5" r="1.6" fill="currentColor"/><circle cx="12" cy="12" r="1.6" fill="currentColor"/><circle cx="12" cy="19" r="1.6" fill="currentColor"/></svg>
          </div>
        </div>

        <div style="height: 1px; background: #ecedf0; margin: 6px 0;"></div>

        <div style="display: flex; align-items: center; gap: 13px; padding: 11px 18px 14px 19px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="color: #5f6368; flex: none;"><path d="M12 9.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5z" stroke="currentColor" stroke-width="1.7"/><path d="M19.4 13.5a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1.03 1.56V20a2 2 0 1 1-4 0v-.09A1.7 1.7 0 0 0 9 18.35a1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.65 14a1.7 1.7 0 0 0-1.56-1.03H3a2 2 0 1 1 0-4h.09A1.7 1.7 0 0 0 4.65 9a1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.7 1.7 0 0 0 9 4.65a1.7 1.7 0 0 0 1.03-1.56V3a2 2 0 1 1 4 0v.09A1.7 1.7 0 0 0 15 4.65a1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.7 1.7 0 0 0 19.35 9c.31.7.99 1.03 1.56 1.03H21a2 2 0 1 1 0 4h-.09a1.7 1.7 0 0 0-1.51 1.03z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
          <span style="font-size: 13.5px; color: #3c4043;">Manage extensions</span>
        </div>
      </div>

    </div>
  </div>
</div>

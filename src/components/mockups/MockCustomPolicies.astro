---
const tenant = "Your company";
---

<div class="thld-mock-frame thld-custom-policies" style="--mock-w: 884; --mock-h: 470;">
  <div class="thld-mock-content">
    <div style="width: 884px; background: #ffffff; border: 1px solid #eceef3; border-radius: 22px; box-shadow: 0 30px 70px -26px rgba(2,14,45,0.3); padding: 24px 26px 22px; box-sizing: border-box; font-family: 'Manrope Variable', system-ui, sans-serif;">

      <!-- Header -->
      <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 20px; margin-bottom: 18px;">
        <div style="display: flex; align-items: center; gap: 13px;">
          <div style="width: 42px; height: 42px; border-radius: 12px; background: #7b36ff; display: flex; align-items: center; justify-content: center; flex: none; box-shadow: 0 6px 16px -3px rgba(123,54,255,0.55);">
            <img src="/emblem-white.svg" alt="" style="width: 27px; height: 27px; object-fit: contain;" />
          </div>
          <div>
            <div style="font-size: 21px; font-weight: 800; color: #0c1430; letter-spacing: -0.02em; line-height: 1.1;">Custom policies</div>
            <div style="font-size: 13.5px; color: #6e7180; font-weight: 500; margin-top: 2px;">Detection rules tuned to your business needs: codenames, internal systems, your naming conventions.</div>
          </div>
        </div>
        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 7px; flex: none;">
          <div style="display: flex; align-items: center; gap: 8px; background: #020e2d; border-radius: 999px; padding: 7px 13px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" style="color: #a98bff;"><path d="M4 21V8l8-5 8 5v13M4 21h16M9 21v-5h6v5M8 11h.01M12 11h.01M16 11h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span style="font-size: 12.5px; font-weight: 700; color: #fff;">{tenant}</span>
          </div>
          <div style="display: flex; align-items: center; gap: 6px; background: #eafaf2; border: 1px solid #bce6d2; border-radius: 999px; padding: 4px 11px; white-space: nowrap;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: #16956a;"></span>
            <span style="font-size: 11px; font-weight: 700; color: #0f7a52; letter-spacing: 0.02em;">14 policies active</span>
          </div>
        </div>
      </div>

      <!-- Policy grid -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 13px;">

        <!-- Project codenames -->
        <div style="background: #fafbfc; border: 1px solid #e7e9f0; border-radius: 16px; padding: 15px 16px;">
          <div style="display: flex; align-items: center; gap: 11px; margin-bottom: 11px;">
            <div style="width: 34px; height: 34px; border-radius: 10px; background: #f2ecff; display: flex; align-items: center; justify-content: center; flex: none;">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" style="color: #7b36ff;"><path d="M3 7v5.6a2 2 0 0 0 .6 1.4l7.4 7.4a2 2 0 0 0 2.8 0l5.6-5.6a2 2 0 0 0 0-2.8L12 5.6A2 2 0 0 0 10.6 5H5a2 2 0 0 0-2 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="8" cy="10" r="1.4" fill="currentColor"/></svg>
            </div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 14.5px; font-weight: 700; color: #1d2433;">Project codenames</div>
              <div style="font-size: 11.5px; color: #9097a8; font-weight: 500;">Internal project &amp; release names</div>
            </div>
            <span style="font-size: 11px; font-weight: 700; color: #e23b30; background: #fde8e6; border: 1px solid #f6ccc7; border-radius: 7px; padding: 4px 9px; flex: none;">Block</span>
          </div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px;">
            <span style="font-family: ui-monospace, monospace; font-size: 11.5px; font-weight: 600; color: #3c4257; background: #eef0f5; border-radius: 6px; padding: 4px 8px;">Project Helios</span>
            <span style="font-family: ui-monospace, monospace; font-size: 11.5px; font-weight: 600; color: #3c4257; background: #eef0f5; border-radius: 6px; padding: 4px 8px;">BlueFin</span>
            <span style="font-family: ui-monospace, monospace; font-size: 11.5px; font-weight: 600; color: #3c4257; background: #eef0f5; border-radius: 6px; padding: 4px 8px;">Project Atlas</span>
          </div>
        </div>

        <!-- Internal systems -->
        <div style="background: #fafbfc; border: 1px solid #e7e9f0; border-radius: 16px; padding: 15px 16px;">
          <div style="display: flex; align-items: center; gap: 11px; margin-bottom: 11px;">
            <div style="width: 34px; height: 34px; border-radius: 10px; background: #e9f2ff; display: flex; align-items: center; justify-content: center; flex: none;">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" style="color: #2b6fd6;"><rect x="3" y="4" width="18" height="7" rx="2" stroke="currentColor" stroke-width="1.8"/><rect x="3" y="13" width="18" height="7" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M7 7.5h.01M7 16.5h.01" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
            </div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 14.5px; font-weight: 700; color: #1d2433;">Internal systems</div>
              <div style="font-size: 11.5px; color: #9097a8; font-weight: 500;">Hostnames, services, endpoints</div>
            </div>
            <span style="font-size: 11px; font-weight: 700; color: #2b6fd6; background: #e6f0ff; border: 1px solid #c4ddff; border-radius: 7px; padding: 4px 9px; flex: none;">Redact</span>
          </div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px;">
            <span style="font-family: ui-monospace, monospace; font-size: 11.5px; font-weight: 600; color: #3c4257; background: #eef0f5; border-radius: 6px; padding: 4px 8px;">atlas-prod-db-01</span>
            <span style="font-family: ui-monospace, monospace; font-size: 11.5px; font-weight: 600; color: #3c4257; background: #eef0f5; border-radius: 6px; padding: 4px 8px;">vault.internal</span>
          </div>
        </div>

        <!-- ID conventions -->
        <div style="background: #fafbfc; border: 1px solid #e7e9f0; border-radius: 16px; padding: 15px 16px;">
          <div style="display: flex; align-items: center; gap: 11px; margin-bottom: 11px;">
            <div style="width: 34px; height: 34px; border-radius: 10px; background: #e9f2ff; display: flex; align-items: center; justify-content: center; flex: none;">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" style="color: #2b6fd6;"><rect x="3" y="5" width="18" height="14" rx="2.5" stroke="currentColor" stroke-width="1.8"/><circle cx="9" cy="11" r="2.2" stroke="currentColor" stroke-width="1.8"/><path d="M6 16c.6-1.6 4.4-1.6 5 0M15 10h3M15 13.5h3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            </div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 14.5px; font-weight: 700; color: #1d2433;">ID conventions</div>
              <div style="font-size: 11.5px; color: #9097a8; font-weight: 500;">Employee &amp; customer ref formats</div>
            </div>
            <span style="font-size: 11px; font-weight: 700; color: #2b6fd6; background: #e6f0ff; border: 1px solid #c4ddff; border-radius: 7px; padding: 4px 9px; flex: none;">Redact</span>
          </div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px;">
            <span style="font-family: ui-monospace, monospace; font-size: 11.5px; font-weight: 600; color: #3c4257; background: #eef0f5; border-radius: 6px; padding: 4px 8px;">NW-EMP-#####</span>
            <span style="font-family: ui-monospace, monospace; font-size: 11.5px; font-weight: 600; color: #3c4257; background: #eef0f5; border-radius: 6px; padding: 4px 8px;">ACC-####-XX</span>
          </div>
        </div>

        <!-- Unreleased products -->
        <div style="background: #fafbfc; border: 1px solid #e7e9f0; border-radius: 16px; padding: 15px 16px;">
          <div style="display: flex; align-items: center; gap: 11px; margin-bottom: 11px;">
            <div style="width: 34px; height: 34px; border-radius: 10px; background: #f2ecff; display: flex; align-items: center; justify-content: center; flex: none;">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" style="color: #7b36ff;"><path d="M21 8l-9-5-9 5 9 5 9-5zM3 8v8l9 5 9-5V8M12 13v8" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
            </div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 14.5px; font-weight: 700; color: #1d2433;">Unreleased products</div>
              <div style="font-size: 11.5px; color: #9097a8; font-weight: 500;">SKUs &amp; roadmap names</div>
            </div>
            <span style="font-size: 11px; font-weight: 700; color: #e23b30; background: #fde8e6; border: 1px solid #f6ccc7; border-radius: 7px; padding: 4px 9px; flex: none;">Block</span>
          </div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px;">
            <span style="font-family: ui-monospace, monospace; font-size: 11.5px; font-weight: 600; color: #3c4257; background: #eef0f5; border-radius: 6px; padding: 4px 8px;">Titan-2</span>
            <span style="font-family: ui-monospace, monospace; font-size: 11.5px; font-weight: 600; color: #3c4257; background: #eef0f5; border-radius: 6px; padding: 4px 8px;">NW-X9</span>
            <span style="font-family: ui-monospace, monospace; font-size: 11.5px; font-weight: 600; color: #3c4257; background: #eef0f5; border-radius: 6px; padding: 4px 8px;">Project Nimbus</span>
          </div>
        </div>

      </div>

      <!-- Bottom note -->
      <div style="display: flex; align-items: center; gap: 12px; margin-top: 14px; background: #faf7ff; border: 1px solid #ece2ff; border-radius: 14px; padding: 13px 16px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="color: #7b36ff; flex: none;"><path d="M12 3l2.5 5.5L20 9l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-.5L12 3z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>
        <span style="font-size: 13px; color: #3c4257; font-weight: 500; line-height: 1.45;"><strong style="color: #0c1430; font-weight: 700;">Define any rule</strong>: keywords, regex, or example phrases. Your conventions and internal names included, enforced on-device so nothing leaves your tenant.</span>
      </div>

    </div>
  </div>
</div>

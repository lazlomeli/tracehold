---
---

<div class="thld-mock-frame thld-chatbot-file" style="--mock-w: 856; --mock-h: 310;">
  <div class="thld-mock-content">
    <div style="position: relative; width: 820px; margin-top: 58px; font-family: 'Manrope Variable', system-ui, sans-serif;">

      <!-- Chat input card -->
      <div style="position: relative; background: #ffffff; border: 1px solid #e9eaf0; border-radius: 26px; box-shadow: 0 24px 60px -18px rgba(2,14,45,0.32), 0 6px 18px -8px rgba(2,14,45,0.18); padding: 22px 26px 16px 26px;">

        <!-- Attached file chip (flagged) -->
        <div style="display: inline-flex; align-items: center; gap: 12px; background: #fff5f4; border: 1px solid #f6c4bf; border-radius: 14px; padding: 10px 14px 10px 11px; max-width: 320px;">
          <div style="width: 40px; height: 40px; border-radius: 10px; background: #020e2d; display: flex; align-items: center; justify-content: center; flex: none; position: relative;">
            <span style="font-size: 11px; font-weight: 700; color: #7bdcff; letter-spacing: 0.02em; font-family: ui-monospace, monospace;">ENV</span>
          </div>
          <div style="min-width: 0;">
            <div style="font-size: 14px; font-weight: 600; color: #202124; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">.env</div>
            <div style="display: flex; align-items: center; gap: 6px; margin-top: 2px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" style="color: #e23b30; flex: none;"><path d="M12 3l9 16H3L12 3z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M12 10v4M12 16.5v.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              <span style="font-size: 12px; font-weight: 600; color: #e23b30;">Secrets detected · 1.4 KB</span>
            </div>
          </div>
          <div style="width: 22px; height: 22px; border-radius: 50%; background: #fde3e0; color: #e23b30; display: flex; align-items: center; justify-content: center; flex: none; margin-left: 2px;">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1 1l8 8M9 1L1 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
          </div>
        </div>

        <!-- Typed message -->
        <div style="font-size: 17px; line-height: 1.6; color: #202124; letter-spacing: -0.01em; padding-right: 46px; margin-top: 16px;">
          Here's our config file, can you fix the database connection string?<span style="display: inline-block; width: 2px; height: 19px; background: #7b36ff; border-radius: 1px; margin-left: 3px; vertical-align: -3px; animation: thld-caret 1.05s steps(1) infinite;"></span>
        </div>

        <!-- Toolbar row -->
        <div style="display: flex; align-items: center; gap: 10px; margin-top: 18px;">
          <div style="width: 34px; height: 34px; border-radius: 50%; border: 1px solid #e6e7ee; display: flex; align-items: center; justify-content: center; color: #5f6368; flex: none;">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <div style="width: 34px; height: 34px; border-radius: 50%; border: 1px solid #e6e7ee; display: flex; align-items: center; justify-content: center; color: #5f6368; flex: none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><rect x="9" y="3" width="6" height="11" rx="3" stroke="currentColor" stroke-width="1.8"/><path d="M6 11a6 6 0 0 0 12 0M12 17v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>

          <div style="flex: 1;"></div>

          <span style="font-size: 12.5px; color: #a3a6b3; font-weight: 500;">Press Enter to send</span>

          <div style="width: 38px; height: 38px; border-radius: 50%; background: #f0eaff; color: #b79cf2; display: flex; align-items: center; justify-content: center; flex: none;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 19V5M12 5l-6 6M12 5l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </div>

        <!-- Tracehold guard overlay -->
        <div style="position: absolute; top: -18px; right: -18px; width: 52px; height: 52px;">
          <div style="position: absolute; inset: 0; border-radius: 16px; background: #7b36ff; animation: thld-pulse 2s ease-out infinite;"></div>
          <div style="position: absolute; inset: 0; border-radius: 16px; background: #7b36ff; animation: thld-pulse 2s ease-out infinite; animation-delay: 1s;"></div>
          <div style="position: absolute; inset: 0; border-radius: 15px; background: #7b36ff; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 20px -4px rgba(123,54,255,0.6); border: 2px solid #ffffff; overflow: hidden;">
            <img src="/emblem-white.svg" alt="Tracehold" style="width: 30px; height: 30px; object-fit: contain;" />
            <div style="position: absolute; top: 0; bottom: 0; width: 14px; background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.55) 50%, rgba(255,255,255,0) 100%); animation: thld-scan 1.8s linear infinite;"></div>
          </div>
        </div>
      </div>

      <!-- Status callout -->
      <div style="position: absolute; top: -58px; right: 46px; display: flex; align-items: center; gap: 9px; background: #020e2d; color: #ffffff; padding: 9px 14px; border-radius: 11px; box-shadow: 0 12px 28px -10px rgba(2,14,45,0.5); white-space: nowrap;">
        <span style="position: relative; width: 8px; height: 8px; flex: none;">
          <span style="position: absolute; inset: 0; border-radius: 50%; background: #ff5a4d;"></span>
          <span style="position: absolute; inset: 0; border-radius: 50%; background: #ff5a4d; animation: thld-pulse 1.8s ease-out infinite;"></span>
        </span>
        <span style="font-size: 13px; font-weight: 600; letter-spacing: -0.01em;">Tracehold · Sensitive file detected</span>
        <span style="position: absolute; bottom: -5px; right: 18px; width: 11px; height: 11px; background: #020e2d; transform: rotate(45deg); border-radius: 2px;"></span>
      </div>

    </div>
  </div>
</div>

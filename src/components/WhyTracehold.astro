---
import PipelineSteps from "./PipelineSteps.astro";
---

<section id="why-tracehold" class="relative overflow-hidden border-b border-[var(--color-cloud)] bg-white py-24 md:py-32">
  <div
    class="pointer-events-none absolute -right-40 top-0 h-[520px] w-[520px] rounded-full opacity-[0.06]"
    style="background: radial-gradient(circle, #7b36ff 0%, transparent 60%);"
    aria-hidden="true"
  >
  </div>

  <div class="container-x relative">
    <div class="grid items-end gap-8 lg:grid-cols-[1.2fr_1fr]">
      <div>
        <div class="eyebrow">
          <span class="inline-block h-px w-8 bg-[var(--color-brand-purple)]"></span>
          What changes on day one
        </div>
        <h2 class="h-section mt-5 text-[var(--color-phantom)]">
          Every prompt gets a verdict.
          <span class="text-[var(--color-graphite)]">Decided on the device.</span>
        </h2>
      </div>
      <div class="lg:justify-self-end">
        <p class="body-lg max-w-[430px]">
          Clean pass, silent watch, redaction or a hard stop. Tracehold decides what happens to every
          prompt before it leaves.
        </p>
        <a href="/how-it-works" class="btn-secondary mt-6">
          View in detail
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="mt-14">
      <PipelineSteps />
    </div>

    <div class="mt-6 grid gap-6 rounded-2xl border border-[var(--color-cloud)] bg-[var(--color-brand-light)]/40 p-7 md:grid-cols-2 md:p-8">
      <div class="flex items-center gap-5">
        <p class="text-[44px] font-extrabold leading-none tracking-tight text-[var(--color-brand-purple)] md:text-[52px]">1,600+</p>
        <div>
          <p class="text-[15px] font-bold text-[var(--color-phantom)]">detection patterns, out of the box</p>
          <p class="body-sm mt-1">Secrets, PII, financial data, source code and intent.</p>
        </div>
      </div>
      <div class="flex items-center gap-4 md:border-l md:border-[var(--color-cloud)] md:pl-8">
        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[var(--color-brand-purple)]/10 text-[var(--color-brand-purple)]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" y1="8" x2="20" y2="8"/><line x1="4" y1="16" x2="20" y2="16"/><circle cx="9" cy="8" r="2.2"/><circle cx="15" cy="16" r="2.2"/>
          </svg>
        </span>
        <div>
          <p class="text-[15px] font-bold text-[var(--color-phantom)]">Bring your own rules</p>
          <p class="body-sm mt-1">Keywords, regex or example phrases, tuned to your business.</p>
        </div>
      </div>
    </div>
  </div>
</section>

---
const promises = [
  {
    title: "Detection runs on-device",
    body: "The DLP engine executes entirely in the browser and on the endpoint. Prompt content never reaches our backend — only metadata (finding type, severity, AI domain, timestamp). Privacy by architecture, not policy.",
    icon: "lock",
  },
  {
    title: "Kernel-level enforcement",
    body: "Our endpoint agent hooks into the kernel itself, intercepting AI egress before TLS encrypts it and before it leaves the host. No browser bypass, no CLI escape hatch — and no competitor has it.",
    icon: "chip",
  },
  {
    title: "Transparent to the employee",
    body: "Every block explains exactly what was detected and why. Never silent. Never punitive. Employees learn what to redact instead of resenting the tool.",
    icon: "eye",
  },
];
---

<section class="relative overflow-hidden border-y border-[var(--color-cloud)] bg-[var(--color-brand-light)]/40 py-24 md:py-32">
  <div class="pointer-events-none absolute -bottom-40 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full opacity-[0.08]" style="background: radial-gradient(circle, #7b36ff 0%, transparent 60%);" aria-hidden="true"></div>

  <div class="container-x relative">
    <div class="mx-auto max-w-[760px] text-center">
      <div class="eyebrow justify-center">
        <span class="inline-block h-px w-8 bg-[var(--color-brand-purple)]"></span>
        Three non-negotiables
        <span class="inline-block h-px w-8 bg-[var(--color-brand-purple)]"></span>
      </div>
      <h2 class="h-section mt-5 text-[var(--color-phantom)]">
        Promises that hold under audit.
      </h2>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {promises.map((p) => (
        <div class="surface-card group flex flex-col !p-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[var(--color-brand-purple)]/10 text-[var(--color-brand-purple)] transition group-hover:bg-[var(--color-brand-purple)] group-hover:text-white">
            {p.icon === "lock" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            )}
            {p.icon === "chip" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="6" y="6" width="12" height="12" rx="2"/>
                <rect x="9" y="9" width="6" height="6"/>
                <line x1="9" y1="2" x2="9" y2="6"/>
                <line x1="15" y1="2" x2="15" y2="6"/>
                <line x1="9" y1="18" x2="9" y2="22"/>
                <line x1="15" y1="18" x2="15" y2="22"/>
                <line x1="2" y1="9" x2="6" y2="9"/>
                <line x1="2" y1="15" x2="6" y2="15"/>
                <line x1="18" y1="9" x2="22" y2="9"/>
                <line x1="18" y1="15" x2="22" y2="15"/>
              </svg>
            )}
            {p.icon === "eye" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            )}
          </div>
          <h3 class="h-card mt-6 text-[var(--color-phantom)]">{p.title}</h3>
          <p class="body mt-3">{p.body}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-3 md:gap-4">
      <span class="text-[11px] font-bold uppercase tracking-[0.18em] text-[var(--color-graphite)]">
        Endpoint agent available on
      </span>

      <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-cloud)] bg-white px-4 py-1.5 text-[13px] font-semibold text-[var(--color-phantom)]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M3 5.4L10.5 4.3v8.2H3V5.4zm0 13.2v-7.1h7.5v8.2L3 18.6zm8.5-14.4L21 3v9.5h-9.5V4.2zm0 16.6V12.5H21V21l-9.5-1.2z"/>
        </svg>
        Windows
      </span>

      <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-cloud)] bg-white px-4 py-1.5 text-[13px] font-semibold text-[var(--color-phantom)]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.5 12.5c0-2.6 2.1-3.8 2.2-3.9-1.2-1.8-3.1-2-3.7-2-1.6-.2-3.1.9-3.9.9s-2-.9-3.4-.9c-1.7 0-3.3 1-4.2 2.6-1.8 3.1-.5 7.7 1.3 10.2.9 1.2 1.9 2.6 3.3 2.6 1.3-.1 1.8-.9 3.4-.9s2 .9 3.4.8c1.4 0 2.3-1.3 3.2-2.5.7-.9 1.2-2 1.4-3.1-1.6-.6-3-2.2-3-3.8zM14.8 5c.7-.9 1.2-2 1.1-3.2-1 0-2.2.7-3 1.5-.7.8-1.3 2-1.1 3.1 1.1.1 2.3-.6 3-1.4z"/>
        </svg>
        macOS
      </span>

      <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-cloud)] bg-white px-4 py-1.5 text-[13px] font-semibold text-[var(--color-phantom)]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 1.5c-2.2 0-4 1.8-4 4 0 .8.2 1.5.6 2.1-.7.4-1.3 1-1.7 1.7-.6 1.1-.9 2.4-.9 3.7 0 1.5.4 2.9 1.1 4.1-.5.6-.9 1.4-.9 2.3 0 1.7 1.4 3.1 3.1 3.1.6 0 1.2-.2 1.7-.5.3.1.7.2 1 .3.4.1.9.1 1.3 0 .3-.1.7-.2 1-.3.5.3 1.1.5 1.7.5 1.7 0 3.1-1.4 3.1-3.1 0-.9-.3-1.7-.9-2.3.7-1.2 1.1-2.6 1.1-4.1 0-1.3-.3-2.6-.9-3.7-.4-.7-1-1.3-1.7-1.7.4-.6.6-1.3.6-2.1 0-2.2-1.8-4-4-4zm-2 4c0-1.1.9-2 2-2s2 .9 2 2-.9 2-2 2-2-.9-2-2zm.5 3.5c.5.2 1 .3 1.5.3s1-.1 1.5-.3c.6.2 1.1.5 1.5 1 .5.7.8 1.5.8 2.5 0 .9-.2 1.8-.6 2.6-.4-.3-.9-.4-1.4-.4-.7 0-1.4.3-1.8.8-.4-.5-1.1-.8-1.8-.8-.5 0-1 .1-1.4.4-.4-.8-.6-1.7-.6-2.6 0-1 .3-1.8.8-2.5.4-.5.9-.8 1.5-1z"/>
        </svg>
        Linux
      </span>
    </div>
  </div>
</section>

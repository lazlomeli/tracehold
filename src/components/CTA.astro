<section id="demo" class="relative overflow-hidden bg-[var(--color-brand-navy)] py-24 text-white md:py-32">
  <div class="absolute -top-1/2 left-1/2 h-[800px] w-[800px] -translate-x-1/2 rounded-full bg-[var(--color-brand-purple)] opacity-20 blur-[180px]" aria-hidden="true"></div>

  <div class="container-x relative">
    <div class="mx-auto max-w-[760px] text-center">
      <img src="/emblem-white.svg" alt="" class="mx-auto h-12 w-auto opacity-80" />
      <h2 class="h-section mt-8 text-white">
        Stop the leaks you can't see.
      </h2>
      <p class="body-lg mt-6 !text-[var(--color-steel)]">
        2–4 week proof of concept in observe-only mode. Zero employee disruption. You'll see, in real numbers,
        what your team is pasting into AI tools today.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <a href="mailto:hello@tracehold.com" class="inline-flex items-center gap-2 rounded-full bg-[var(--color-brand-purple)] px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-white hover:text-[var(--color-phantom)]">
          Request a demo
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="#" class="inline-flex items-center gap-2 rounded-full border border-white/25 px-6 py-3.5 text-sm font-semibold text-white transition hover:border-white">
          Download the compliance one-pager
        </a>
      </div>

      <p class="mt-8 text-[12px] uppercase tracking-[0.16em] text-[var(--color-space)]">
        Trusted by security teams across Banking, Insurance, Health and the Public Sector
      </p>
    </div>
  </div>
</section>

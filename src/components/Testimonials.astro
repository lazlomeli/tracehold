---
const quotes = [
  {
    text: "Our auditors stopped asking 'what about AI?' the week we deployed Tracehold. The event log answers it for them.",
    author: "Head of Information Security",
    org: "EU-listed insurer · 4,200 seats",
    accent: false,
  },
  {
    text: "I expected a noisy tool. Three weeks in, the only false positive my team flagged was a sample SSH key in our own README.",
    author: "CISO",
    org: "Fintech · 800 seats",
    accent: true,
  },
  {
    text: "The eBPF agent caught a junior dev pasting our entire payments service into Claude Code. Twice. The training that came after was free.",
    author: "VP Platform Engineering",
    org: "Software factory · 1,500 devs",
    accent: false,
  },
  {
    text: "Deployed via Intune in an afternoon. No tickets, no proxy. By Monday morning we had a clean dashboard.",
    author: "IT Operations Lead",
    org: "Spanish public sector",
    accent: false,
  },
];
---

<section class="border-y border-[var(--color-cloud)] bg-[var(--color-brand-light)]/40 py-24 md:py-32">
  <div class="container-x">
    <div class="mx-auto max-w-[760px] text-center">
      <div class="eyebrow justify-center">
        <span class="inline-block h-px w-8 bg-[var(--color-brand-purple)]"></span>
        What security teams say
        <span class="inline-block h-px w-8 bg-[var(--color-brand-purple)]"></span>
      </div>
      <h2 class="h-section mt-5 text-[var(--color-phantom)]">
        Quiet wins. Loud audit trail.
      </h2>
    </div>

    <div class="mt-16 grid gap-5 md:grid-cols-2">
      {quotes.map((q) => (
        <figure class={`relative overflow-hidden rounded-2xl border p-8 transition ${q.accent ? "border-transparent bg-[var(--color-brand-navy)] text-white" : "border-[var(--color-cloud)] bg-white hover:border-[var(--color-phantom)]"}`}>
          {q.accent && (
            <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-[var(--color-brand-purple)] opacity-40 blur-3xl" aria-hidden="true"></div>
          )}

          <svg class={`relative h-7 w-7 ${q.accent ? "text-[var(--color-brand-purple)]" : "text-[var(--color-brand-purple)]"}`} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9.17 6C5.78 6 3 8.78 3 12.17V20h7v-7H6.5c0-1.93 1.34-3.5 3.27-3.5V6h-.6zM20.17 6c-3.39 0-6.17 2.78-6.17 6.17V20h7v-7h-3.5c0-1.93 1.34-3.5 3.27-3.5V6h-.6z"/>
          </svg>

          <blockquote class={`relative mt-5 text-[18px] font-medium leading-snug tracking-[-0.005em] ${q.accent ? "text-white" : "text-[var(--color-phantom)]"}`}>
            {q.text}
          </blockquote>

          <figcaption class={`relative mt-6 border-t pt-5 ${q.accent ? "border-white/15" : "border-[var(--color-cloud)]"}`}>
            <p class={`text-[14px] font-bold ${q.accent ? "text-white" : "text-[var(--color-phantom)]"}`}>{q.author}</p>
            <p class={`mt-0.5 text-[12.5px] ${q.accent ? "text-[var(--color-steel)]" : "text-[var(--color-graphite)]"}`}>{q.org}</p>
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="mt-10 text-center text-[12px] uppercase tracking-[0.16em] text-[var(--color-graphite)]">
      Names withheld per pilot NDA · Available on reference call
    </p>
  </div>
</section>

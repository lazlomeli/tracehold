---
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-[var(--color-brand-navy)] text-[var(--color-steel)]">
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 h-[1100px] w-[1100px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-40"
    style="background: radial-gradient(circle, #7b36ff 0%, transparent 62%);"
    aria-hidden="true"
  >
  </div>

  <!-- Call to action -->
  <section id="demo" class="relative py-24 text-white md:py-32">
    <div class="container-x">
      <div class="mx-auto max-w-[760px] text-center">
        <img src="/emblem-white.svg" alt="" class="mx-auto h-12 w-auto opacity-80" />
        <h2 class="h-section mt-8 text-white">
          Stop the leaks you can't see.
        </h2>
        <p class="body-lg mt-6 !text-[var(--color-steel)]">
          2–4 week proof of concept in observe-only mode. Zero employee disruption. You'll see, in real numbers,
          what your team is pasting into AI tools today.
        </p>

        <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
          <a href="mailto:hello@tracehold.com" class="inline-flex items-center gap-2 rounded-full bg-[var(--color-brand-purple)] px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-white hover:text-[var(--color-phantom)]">
            Request a demo
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#" class="inline-flex items-center gap-2 rounded-full border border-white/25 px-6 py-3.5 text-sm font-semibold text-white transition hover:border-white">
            Download the compliance one-pager
          </a>
        </div>

        <p class="mt-8 text-[12px] uppercase tracking-[0.16em] text-[var(--color-space)]">
          Trusted by security teams across Banking, Insurance, Health and the Public Sector
        </p>
      </div>
    </div>
  </section>

  <!-- Footer columns -->
  <div class="relative container-x pb-16">
    <div class="grid gap-12 border-t border-white/10 pt-14 md:grid-cols-[1.5fr_1fr_1fr_1fr]">
      <div>
        <div class="flex items-center">
          <img src="/logo-white.svg" alt="Tracehold" class="h-8 w-auto" />
        </div>
        <p class="mt-5 max-w-[320px] text-[14px] leading-relaxed text-[var(--color-space)]">
          AI-native data loss prevention. Built so prompts never leave the browser.
        </p>
      </div>

      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-white">Product</p>
        <ul class="mt-4 space-y-2.5 text-[14px]">
          <li><a href="/platform" class="transition hover:text-white">Platform</a></li>
          <li><a href="/how-it-works" class="transition hover:text-white">How it works</a></li>
          <li><a href="/platform#detect" class="transition hover:text-white">What we detect</a></li>
          <li><a href="/platform#cli" class="transition hover:text-white">CLI agents</a></li>
          <li><a href="/#pricing" class="transition hover:text-white">Pricing</a></li>
        </ul>
      </div>

      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-white">Company</p>
        <ul class="mt-4 space-y-2.5 text-[14px]">
          <li><a href="#" class="transition hover:text-white">About</a></li>
          <li><a href="#" class="transition hover:text-white">Security</a></li>
          <li><a href="#" class="transition hover:text-white">Careers</a></li>
          <li><a href="#" class="transition hover:text-white">Contact</a></li>
        </ul>
      </div>

      <div>
        <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-white">Legal</p>
        <ul class="mt-4 space-y-2.5 text-[14px]">
          <li><a href="#" class="transition hover:text-white">Privacy</a></li>
          <li><a href="#" class="transition hover:text-white">Terms</a></li>
          <li><a href="#" class="transition hover:text-white">DPA</a></li>
          <li><a href="#" class="transition hover:text-white">Subprocessors</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-3 border-t border-white/10 pt-6 text-[12px] text-[var(--color-space)] md:flex-row md:items-center md:justify-between">
      <p>© {year} Tracehold. All rights reserved.</p>
      <p>Made for CISOs who can't sleep.</p>
    </div>
  </div>
</footer>

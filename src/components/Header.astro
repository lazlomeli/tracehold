---
---

<header
  id="site-header"
  class="site-header sticky top-0 z-50 w-full border-b border-[var(--color-cloud)] bg-white/85 backdrop-blur-md"
>
  <div class="container-x flex h-16 items-center justify-between">
    <a href="/" class="flex items-center" aria-label="Tracehold home">
      <img src="/logo-dark.svg" alt="Tracehold" class="h-7 w-auto" />
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      <a href="/" class="text-sm font-medium text-[var(--color-arsenic)] transition hover:text-[var(--color-phantom)]">Home</a>
      <a href="/how-it-works" class="text-sm font-medium text-[var(--color-arsenic)] transition hover:text-[var(--color-phantom)]">How it works</a>
      <a href="/platform" class="text-sm font-medium text-[var(--color-arsenic)] transition hover:text-[var(--color-phantom)]">Platform</a>
      <a href="/#pricing" class="text-sm font-medium text-[var(--color-arsenic)] transition hover:text-[var(--color-phantom)]">Pricing</a>
      <a href="/#faq" class="text-sm font-medium text-[var(--color-arsenic)] transition hover:text-[var(--color-phantom)]">FAQ</a>
    </nav>

    <div class="flex items-center gap-2">
      <a href="/#demo" class="btn-secondary !px-4 !py-2 !text-[13px]">
        Request demo
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    --scroll-progress: 0;
  }
  .site-header::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -1px;
    height: 1px;
    width: calc(var(--scroll-progress) * 100%);
    background-color: #7b36ff;
    pointer-events: none;
  }
</style>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    let ticking = false;
    const update = () => {
      const doc = document.documentElement;
      const max = doc.scrollHeight - window.innerHeight;
      const progress = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
      header.style.setProperty("--scroll-progress", String(progress));
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    };
    update();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
  }
</script>

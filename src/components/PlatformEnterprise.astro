---
const pillars = [
  {
    label: "Deploy",
    body: "Push the browser extension via GPO, Intune or Jamf. Add the endpoint agent for terminal AI tools when you need it.",
  },
  {
    label: "Identity",
    body: "SSO with OIDC and SAML. Sync users and groups from LDAP or Active Directory.",
  },
  {
    label: "SIEM export",
    body: "Stream events to Splunk, syslog or any webhook, with a delivery log you can audit.",
  },
  {
    label: "Multi-tenant",
    body: "Hierarchical isolation for MSPs and MSSPs: run many client orgs with read-only roll-ups.",
  },
];

const frameworks = ["GDPR", "ISO 27001", "NIS2", "SOC 2"];
const badges = [
  "Encrypted in transit & at rest",
  "Strict tenant isolation",
  "SOC 2 Type II in progress",
];
---

<section id="enterprise" class="border-y border-[var(--color-cloud)] bg-[var(--color-brand-light)]/40 py-24 md:py-32">
  <div class="container-x">
    <div class="grid items-end gap-8 lg:grid-cols-[1.2fr_1fr]">
      <div>
        <div class="eyebrow">
          <span class="inline-block h-px w-8 bg-[var(--color-brand-purple)]"></span>
          Built for enterprise
        </div>
        <h2 class="h-section mt-5 text-[var(--color-phantom)]">
          Fits the way your organization
          <span class="text-[var(--color-graphite)]">already runs.</span>
        </h2>
      </div>
      <p class="body-lg max-w-[440px] lg:justify-self-end">
        Identity, deployment, SIEM and multi-tenant. Tracehold drops into your stack instead of
        fighting it.
      </p>
    </div>

    <div class="mt-14 grid gap-px overflow-hidden rounded-2xl bg-[var(--color-cloud)] md:grid-cols-2 lg:grid-cols-4">
      {pillars.map((p) => (
        <article class="bg-white p-7 transition hover:bg-[var(--color-brand-light)]/40">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[var(--color-brand-purple)]">{p.label}</p>
          <p class="mt-3 text-[13.5px] leading-relaxed text-[var(--color-graphite)]">{p.body}</p>
        </article>
      ))}
    </div>

    <div class="mt-6 grid gap-6 lg:grid-cols-[1.3fr_1fr]">
      <div class="rounded-2xl border border-[var(--color-cloud)] bg-white p-7">
        <div class="eyebrow">
          <span class="inline-block h-px w-8 bg-[var(--color-brand-purple)]"></span>
          Compliance reporting
        </div>
        <h3 class="h-card mt-4 text-[var(--color-phantom)]">
          One-click evidence, mapped to the frameworks that matter.
        </h3>
        <p class="body mt-2.5">
          Exportable reports and an immutable audit log, per organization and per event.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          {frameworks.map((f) => (
            <span class="rounded-full border border-[var(--color-cloud)] bg-[var(--color-brand-light)]/60 px-3 py-1 text-[12px] font-semibold text-[var(--color-phantom)]">{f}</span>
          ))}
        </div>
      </div>

      <div class="grid gap-3">
        {badges.map((b) => (
          <div class="flex items-center gap-3 rounded-xl border border-[var(--color-cloud)] bg-white px-5 py-4">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-success)]/10 text-[var(--color-success)]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="text-[13px] font-semibold text-[var(--color-phantom)]">{b}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
const pillars = [
  {
    label: "Browser",
    title: "Manifest V3 extension",
    body: "Chromium and Firefox. Two enforcement layers — DOM gate + network gate — so no button bypass works.",
  },
  {
    label: "Backend",
    title: "Node 20 + PostgreSQL 16",
    body: "Strict tenant isolation with row-level security and a non-bypass database role. Audit-grade by design.",
  },
  {
    label: "Identity",
    title: "SSO, LDAP, SCIM-ready",
    body: "OIDC and SAML 2.0 out of the box. LDAP sync with encrypted bind. Per-org secrets in AES-256-GCM.",
  },
  {
    label: "Egress",
    title: "SIEM in under 60 seconds",
    body: "Splunk HEC, Sentinel, CEF/syslog, webhooks. Retried, escaped, observable in a delivery log.",
  },
];
---

<section id="product" class="bg-white py-24 md:py-32">
  <div class="container-x">
    <div class="grid items-end gap-8 lg:grid-cols-[1.2fr_1fr]">
      <div>
        <div class="eyebrow">
          <span class="inline-block h-px w-8 bg-[var(--color-brand-purple)]"></span>
          Architecture
        </div>
        <h2 class="h-section mt-5 text-[var(--color-phantom)]">
          Built like infrastructure.
          <span class="text-[var(--color-graphite)]">Priced like software.</span>
        </h2>
      </div>
      <p class="body-lg max-w-[440px] lg:justify-self-end">
        Every layer is designed to either fail closed or fail safe. No single component
        is your only line of defense.
      </p>
    </div>

    <div class="mt-14 grid gap-px overflow-hidden rounded-2xl bg-[var(--color-cloud)] md:grid-cols-2 lg:grid-cols-4">
      {pillars.map((p) => (
        <article class="bg-white p-7 transition hover:bg-[var(--color-brand-light)]/40">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[var(--color-brand-purple)]">{p.label}</p>
          <h3 class="mt-4 text-[17px] font-bold leading-snug text-[var(--color-phantom)]">{p.title}</h3>
          <p class="mt-3 text-[13.5px] leading-relaxed text-[var(--color-graphite)]">{p.body}</p>
        </article>
      ))}
    </div>

    <div class="mt-10 grid gap-3 sm:grid-cols-3">
      <div class="flex items-center gap-3 rounded-xl border border-[var(--color-cloud)] bg-white px-5 py-4">
        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-success)]/10 text-[var(--color-success)]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <span class="text-[13px] font-semibold text-[var(--color-phantom)]">AES-256-GCM at rest</span>
      </div>
      <div class="flex items-center gap-3 rounded-xl border border-[var(--color-cloud)] bg-white px-5 py-4">
        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-success)]/10 text-[var(--color-success)]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <span class="text-[13px] font-semibold text-[var(--color-phantom)]">TLS-only in transit</span>
      </div>
      <div class="flex items-center gap-3 rounded-xl border border-[var(--color-cloud)] bg-white px-5 py-4">
        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-success)]/10 text-[var(--color-success)]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <span class="text-[13px] font-semibold text-[var(--color-phantom)]">SOC 2 Type II in progress</span>
      </div>
    </div>
  </div>
</section>
